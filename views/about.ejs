<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <meta
        name="description"
        content="Sudanese Youth Hub connects and empowers Sudanese youth through arts, peace, music, technology, workshops, and community initiatives."
    >

    <title>Sudanese Youth Hub | About</title>

    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/about.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link
        href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet"
    >
</head>

<body>

    <%- include("partials/navbar") %>

    <main>

        <!-- About Hero -->
        <section class="about-hero">
            <div class="about-hero-content reveal">
                <p class="section-label">About Our Community</p>

                <h1>
                    Empowering Sudanese Youth to
                    <span>Create, Connect and Lead</span>
                </h1>

                <p>
                    We provide a welcoming platform where Sudanese youth can
                    develop skills, share ideas, build meaningful connections
                    and create positive change in their communities.
                </p>

                <a href="#who-we-are" class="about-btn">
                    Discover Our Story
                </a>
            </div>

            <div class="about-hero-shape shape-one"></div>
            <div class="about-hero-shape shape-two"></div>
        </section>


        <!-- Who We Are -->
        <section class="who section-wrapper" id="who-we-are">

            <div class="who-text reveal">
                <p class="section-label">Our Identity</p>
                <h2>Who We Are</h2>

                <p>
                    Sudanese Youth Hub is a dynamic organization dedicated to
                    empowering Sudanese youth through arts, peacebuilding,
                    music, technology, workshops and community engagement.
                </p>

                <p>
                    Our mission is to create a platform that supports
                    creativity, collaboration, personal growth and youth-led
                    change.
                </p>
            </div>

            <div class="who-image reveal">
                <div class="image-accent"></div>

                <img
                    src="/images/who-we-are.jpeg"
                    alt="Sudanese Youth Hub members"
                >
            </div>

        </section>


        <!-- Leaders -->
        <section class="leaders-section">

            <div class="section-heading reveal">
                <p class="section-label">Meet the Team</p>
                <h2>Our Leaders</h2>

                <p>
                    Meet the people working together to guide, support and
                    grow the Sudanese Youth Hub community.
                </p>
            </div>

            <div class="leaders">

                <article class="leader reveal">
                    <div class="leader-image">
                        <img
                            src="/images/founder.jpeg"
                            alt="Founder of Sudanese Youth Hub"
                        >
                    </div>

                    <div class="leader-info">
                        <p class="leader-role">Founder</p>
                        <h3>John Doe</h3>
                    </div>
                </article>

                <article class="leader reveal">
                    <div class="leader-image">
                        <img
                            src="/images/ceo.jpeg"
                            alt="CEO of Sudanese Youth Hub"
                        >
                    </div>

                    <div class="leader-info">
                        <p class="leader-role">Chief Executive Officer</p>
                        <h3>Safaa Elshikh</h3>
                    </div>
                </article>

                <article class="leader reveal">
                    <div class="leader-image">
                        <img
                            src="/images/manager.jpeg"
                            alt="Manager of Sudanese Youth Hub"
                        >
                    </div>

                    <div class="leader-info">
                        <p class="leader-role">Manager</p>
                        <h3>Monzer Yousif</h3>
                    </div>
                </article>

                <article class="leader reveal">
                    <div class="leader-image">
                        <img
                            src="/images/finance.jpeg"
                            alt="Finance Director of Sudanese Youth Hub"
                        >
                    </div>

                    <div class="leader-info">
                        <p class="leader-role">Finance Director</p>
                        <h3>Mohammed Abdirahman</h3>
                    </div>
                </article>

                <article class="leader reveal">
                    <div class="leader-image">
                        <img
                            src="/images/it.jpeg"
                            alt="IT Director of Sudanese Youth Hub"
                        >
                    </div>

                    <div class="leader-info">
                        <p class="leader-role">IT Director</p>
                        <h3>Aliaa Hassan</h3>
                    </div>
                </article>

            </div>

        </section>


        <!-- When We Started -->
        <section class="when-section">

            <div class="when section-wrapper">

                <div class="when-text reveal">
                    <p class="section-label">Our Beginning</p>
                    <h2>When We Started</h2>

                    <p>
                        Sudanese Youth Hub was founded in 2026 with the vision
                        of creating a vibrant and supportive community for
                        Sudanese youth.
                    </p>

                    <p>
                        Since its beginning, the organization has been involved
                        in projects and initiatives that promote personal
                        development, creativity and positive social change.
                    </p>

                    <div class="year-highlight">
                        <span>Founded</span>
                        <strong>2026</strong>
                    </div>
                </div>

                <div class="story reveal">

                    <div class="story-image">
                        <img
                            src="/images/our-story.jpg"
                            alt="The story of Sudanese Youth Hub"
                        >
                    </div>

                    <div class="story-text">
                        <h3>Our Story</h3>

                        <p>
                            Our journey began with a group of passionate young
                            people who recognized the need for a platform that
                            could support and empower Sudanese youth.
                        </p>

                        <p>
                            Through collaboration, creativity and dedication,
                            we have grown into a community that continues to
                            create meaningful opportunities for young people.
                        </p>
                    </div>

                </div>

            </div>

        </section>


        <!-- Where We Operate -->
        <section class="where section-wrapper">

            <div class="where-text reveal">
                <p class="section-label">Our Location</p>
                <h2>Where We Operate</h2>

                <p>
                    Sudanese Youth Hub engages Sudanese youth through
                    community programs, workshops, events and collaborative
                    activities.
                </p>

                <p>
                    Our programs are designed to reach young people from
                    diverse backgrounds and provide opportunities for
                    learning, leadership and community involvement.
                </p>

                <div class="location-details">
                    <strong>Sudanese Youth Hub</strong>
                    <span>Kampala, Uganda</span>
                </div>
            </div>

            <div class="map-container reveal">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.8640000000003!2d32.559999999999995!3d15.500000000000002!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1764b6c7c8c8c8c8%3A0x1a2b3c4d5e6f7g8!2sSudanese%20Youth%20Hub!5e0!3m2!1sen!2ssd!4v1678901234567!5m2!1sen!2ssd"
                    title="Sudanese Youth Hub location"
                    loading="lazy"
                    allowfullscreen
                    referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
            </div>

        </section>


        <!-- What We Do -->
        <section class="what-section">

            <div class="what reveal">
                <p class="section-label">Our Work</p>
                <h2>What We Do</h2>

                <p class="what-intro">
                    We create programs that allow young people to learn,
                    express themselves, build skills and contribute to their
                    communities.
                </p>

                <div class="activities-grid">

                    <article class="activity-card">
                        <span class="activity-icon">🎨</span>
                        <h3>Arts and Culture</h3>
                        <p>
                            Creative events, exhibitions and activities that
                            celebrate Sudanese identity and youth expression.
                        </p>
                    </article>

                    <article class="activity-card">
                        <span class="activity-icon">🕊️</span>
                        <h3>Peacebuilding</h3>
                        <p>
                            Dialogues and workshops that encourage peace,
                            understanding and collaboration.
                        </p>
                    </article>

                    <article class="activity-card">
                        <span class="activity-icon">🎵</span>
                        <h3>Music</h3>
                        <p>
                            Music programs that help young people express
                            themselves and connect through creativity.
                        </p>
                    </article>

                    <article class="activity-card">
                        <span class="activity-icon">💻</span>
                        <h3>Technology</h3>
                        <p>
                            Digital learning, technical workshops and
                            opportunities to develop modern skills.
                        </p>
                    </article>

                    <article class="activity-card">
                        <span class="activity-icon">🤝</span>
                        <h3>Community Service</h3>
                        <p>
                            Youth-led initiatives that respond to community
                            needs and create positive social impact.
                        </p>
                    </article>

                    <article class="activity-card">
                        <span class="activity-icon">🌱</span>
                        <h3>Leadership</h3>
                        <p>
                            Training and mentorship that prepare youth to lead
                            projects, teams and community initiatives.
                        </p>
                    </article>

                </div>
            </div>

        </section>

    </main>

    <%- include("partials/footer") %>

    <script src="/js/main.js"></script>

</body>
</html>