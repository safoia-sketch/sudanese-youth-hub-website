<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <meta
        name="description"
        content="Sudanese Youth Hub connects and empowers Sudanese youth through arts, peace, music, technology, workshops, and community initiatives."
    >

    <title>Sudanese Youth Hub | Contact</title>

    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/contacts.css">
</head>

<body>

    <%
        const contactData =
            typeof formData !== "undefined" && formData
                ? formData
                : {};

        const contactSuccess =
            typeof successMessage !== "undefined"
                ? successMessage
                : null;

        const contactError =
            typeof errorMessage !== "undefined"
                ? errorMessage
                : null;

        const contactValidationErrors =
            typeof errors !== "undefined" && Array.isArray(errors)
                ? errors
                : [];

        const subscriberData =
            typeof newsletterFormData !== "undefined" &&
            newsletterFormData
                ? newsletterFormData
                : {};

        const subscriberSuccess =
            typeof newsletterSuccessMessage !== "undefined"
                ? newsletterSuccessMessage
                : null;

        const subscriberError =
            typeof newsletterErrorMessage !== "undefined"
                ? newsletterErrorMessage
                : null;

        const subscriberValidationErrors =
            typeof newsletterErrors !== "undefined" &&
            Array.isArray(newsletterErrors)
                ? newsletterErrors
                : [];
    %>

    <%- include("partials/navbar") %>

    <main>
        <div class="contact-container">
            <h1>Contact Us</h1>

            <p>
                We would love to hear from you! Please fill out the form below
                and we will get back to you as soon as possible.
            </p>

            <% if (contactSuccess) { %>
                <div class="form-alert success-alert">
                    <%= contactSuccess %>
                </div>
            <% } %>

            <% if (contactError) { %>
                <div class="form-alert error-alert">
                    <%= contactError %>
                </div>
            <% } %>

            <% if (contactValidationErrors.length > 0) { %>
                <ul class="validation-errors">
                    <% contactValidationErrors.forEach((error) => { %>
                        <li><%= error.msg %></li>
                    <% }) %>
                </ul>
            <% } %>

            <form
                action="/contact"
                method="POST"
                class="contact-form"
            >
                <label for="name">Name:</label>

                <input
                    type="text"
                    id="name"
                    name="name"
                    value="<%= contactData.name || '' %>"
                    required
                >

                <label for="email">Email:</label>

                <input
                    type="email"
                    id="email"
                    name="email"
                    value="<%= contactData.email || '' %>"
                    required
                >

                <label for="subject">Subject:</label>

                <input
                    type="text"
                    id="subject"
                    name="subject"
                    value="<%= contactData.subject || '' %>"
                    required
                >

                <label for="message">Message:</label>

                <textarea
                    id="message"
                    name="message"
                    rows="5"
                    required
                ><%= contactData.message || '' %></textarea>

                <button type="submit">
                    Send Message
                </button>
            </form>
        </div>

        <div class="newsletter-container">
            <h2>Subscribe to Our Newsletter</h2>

            <p>
                Stay updated with the latest news and events from Sudanese
                Youth Hub. Enter your email below to subscribe to our
                newsletter.
            </p>

            <% if (subscriberSuccess) { %>
                <div class="form-alert success-alert">
                    <%= subscriberSuccess %>
                </div>
            <% } %>

            <% if (subscriberError) { %>
                <div class="form-alert error-alert">
                    <%= subscriberError %>
                </div>
            <% } %>

            <% if (subscriberValidationErrors.length > 0) { %>
                <ul class="validation-errors">
                    <% subscriberValidationErrors.forEach((error) => { %>
                        <li><%= error.msg %></li>
                    <% }) %>
                </ul>
            <% } %>

            <form
                action="/subscribe"
                method="POST"
                class="newsletter-form"
            >
                <label for="newsletterFullName">
                    Full Name:
                </label>

                <input
                    type="text"
                    id="newsletterFullName"
                    name="fullName"
                    value="<%= subscriberData.fullName || '' %>"
                    placeholder="Enter your full name"
                >

                <label for="newsletterEmail">
                    Email Address:
                </label>

                <input
                    type="email"
                    id="newsletterEmail"
                    name="email"
                    value="<%= subscriberData.email || '' %>"
                    placeholder="Enter your email address"
                    required
                >

                <button type="submit">
                    Subscribe
                </button>
            </form>
        </div>

        <div class="address-container">
            <h2>Our Address</h2>

            <p>
                Sudanese Youth Hub<br>
                123 Main Street<br>
                Khartoum, Sudan<br>
                Phone: +249 123 456 789<br>

                Email:
                <a href="mailto:info@sudaneseyouthhub.org">
                    info@sudaneseyouthhub.org
                </a>
            </p>

            <h2>Follow Us on Social Media</h2>

            <div class="social-media-links">
                <a
                    href="https://www.facebook.com"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Facebook
                </a>

                <a
                    href="https://www.twitter.com"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Twitter
                </a>

                <a
                    href="https://www.instagram.com"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Instagram
                </a>
            </div>
        </div>
    </main>

    <%- include("partials/footer") %>

    <script src="/js/main.js"></script>
</body>
</html>